# Local .terraform directories
**/.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Terraform working directory
.terraform/

# Terraform lock file (local only)
.terraform.lock.hcl

# Terraform CLI config
.terraformrc
terraform.rc

# Override files
*_override.tf
*_override.tf.json

# Module directories
.terraform/modules/

# Environment variables
.env
*.env

# IDE files (IntelliJ/PyCharm/VSCode)
.idea/
.idea/**/*
.vscode/
.vscode/**/*

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
env/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Docker
.dockerignore

# Logs
*.log

# Database
db/
db.sqlite*
